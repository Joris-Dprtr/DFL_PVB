   "cell_type": "code",
   "source": [
    "from sklearn.preprocessing import MinMaxScaler\n",
    "\n",
    "# Create a new DataFrame to store scaled values\n",
    "scaled_data = combined_df.copy()\n",
    "\n",
    "# Initialize the MinMaxScaler\n",
    "scaler = MinMaxScaler()\n",
    "\n",
    "# Get unique building names\n",
    "buildings = combined_df.index.get_level_values(0).unique()\n",
    "\n",
    "for building in buildings:\n",
    "    # Filter rows for the current building\n",
    "    current_building = combined_df.loc[building].copy()\n",
    "\n",
    "    # Apply MinMaxScaler to 'MSE' and 'Cost'\n",
    "    current_building[['MSE', 'Cost']] = scaler.fit_transform(current_building[['MSE', 'Cost']])\n",
    "\n",
    "    # Assign back to scaled_data\n",
    "    scaled_data.loc[building] = current_building"
   ],
